{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencareerformat.org/schema-core.json",
  "title": "Open Career Format Starter/Core Authoring Shape",
  "description": "A small LLM-friendly entry point for creating or reviewing a starter OCF. This is not a replacement for the full OCF schema. Use https://opencareerformat.org/schema.json for canonical validation. The overlapping fields named here use the same names and compatible shapes as the full schema. Use this core shape when converting a resume, LinkedIn export, notes, or a job-search conversation into a useful first OCF file. If you need fields not represented here, read the full schema instead of inventing core-only aliases.",
  "type": "object",
  "required": [
    "schemaVersion",
    "person"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "For a canonical OCF file, use https://opencareerformat.org/schema.json."
    },
    "schemaVersion": {
      "type": "string",
      "const": "0.3",
      "description": "The OCF schema version used by the file, for example 0.3."
    },
    "meta": {
      "type": "object",
      "description": "Basic file metadata. Starter files should set fileRole and lastModified when known. A candidate-owned master usually sets canonical=true, fileRole=candidate-master, and variant=master. Imported or converted source material should use source.kind and reviewStatus/provenance on items rather than a separate provisional file role.",
      "properties": {
        "canonical": {
          "type": "boolean"
        },
        "fileRole": {
          "type": "string",
          "enum": [
            "candidate-master",
            "candidate-curated",
            "third-party-working",
            "export-ready",
            "other"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "master",
            "public-profile",
            "role-targeted",
            "company-targeted",
            "portfolio",
            "other"
          ]
        },
        "lastModified": {
          "type": "string",
          "format": "date"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "authored",
                "imported",
                "converted",
                "merged",
                "translated"
              ]
            }
          },
          "additionalProperties": false
        },
        "parentFileId": {
          "type": "string",
          "description": "The meta.id of the OCF file this file was prepared from. Use this for candidate-curated, export-ready, converted, translated, or other child files. The parent remains the source of truth for facts unless this file is explicitly accepted as a replacement master."
        },
        "parentVersion": {
          "type": "string",
          "description": "The parent file's meta.version at the time this child file was created. Compare against the current parent meta.version to decide whether this file may be stale."
        },
        "lineageNotes": {
          "type": "string",
          "description": "Freeform notes about how this file was prepared from its parent: target role, audience, filtering choices, translation context, source conversion details, private material removed, or other curation/export decisions."
        }
      },
      "additionalProperties": false
    },
    "person": {
      "type": "object",
      "required": [
        "name"
      ],
      "description": "The subject of this OCF: the person whose career is described. The subject is not necessarily the controller of this file or the actor that created/edited its contents. Avoid government identifiers and account secrets.",
      "properties": {
        "name": {
          "type": "object",
          "required": [
            "renderAs"
          ],
          "properties": {
            "renderAs": {
              "type": "string"
            },
            "given": {
              "type": "string"
            },
            "family": {
              "type": "string"
            },
            "preferred": {
              "type": "string"
            },
            "pronouns": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "headline": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "value"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "email",
                  "phone",
                  "url",
                  "linkedin",
                  "github",
                  "social",
                  "other"
                ]
              },
              "value": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "primary": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "remote": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "workAuthorization": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "country": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "description": "e.g. citizen, permanent-resident, visa-required"
              },
              "id": {
                "type": "string",
                "description": "Stable local ID for this work authorization statement. Optional unless another item references it; if present, future editors must preserve it."
              },
              "renderAs": {
                "type": "string",
                "description": "Resume-facing display wording, e.g. Authorized to work in the US; no sponsorship required."
              },
              "visibility": {
                "$ref": "#/$defs/visibilityPrivate"
              },
              "reviewStatus": {
                "$ref": "#/$defs/reviewStatus"
              },
              "reviewNote": {
                "type": "string",
                "description": "Short note explaining review status, correction, or remaining concern."
              },
              "reviewedBy": {
                "type": "string",
                "description": "Person or tool that last set or confirmed reviewStatus."
              },
              "reviewedDate": {
                "$ref": "#/$defs/partialDate"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "sourceArtifacts": {
      "type": "array",
      "description": "Old resumes, LinkedIn exports, pasted notes, screenshots, photos, videos, job descriptions, or conversations used as source material.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "capturedDate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "resume",
              "cover-letter",
              "linkedin-export",
              "portfolio-bio",
              "application-draft",
              "chat-paste",
              "chat-attachment",
              "interview-transcript",
              "manual-note",
              "other"
            ]
          },
          "label": {
            "type": "string"
          },
          "capturedDate": {
            "$ref": "#/$defs/partialDate"
          },
          "artifactDate": {
            "$ref": "#/$defs/partialDate"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "experience": {
      "type": "array",
      "description": "All work history in one chronological list. Include jobs, self-employment, military service, caregiving, career breaks, and similar periods when relevant.",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "employment",
              "self-employment",
              "consulting",
              "gig",
              "seasonal",
              "military",
              "government",
              "homemaker",
              "caregiver",
              "career-break",
              "retirement",
              "other"
            ]
          },
          "name": {
            "type": "string"
          },
          "dateRange": {
            "$ref": "#/$defs/dateRange"
          },
          "positions": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/position"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "institution"
        ],
        "properties": {
          "institution": {
            "type": "string"
          },
          "degree": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "dateRange": {
            "$ref": "#/$defs/dateRange"
          },
          "achievements": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/achievement"
            }
          },
          "visibility": {
            "$ref": "#/$defs/visibility"
          }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "tool",
              "platform",
              "language",
              "framework",
              "methodology",
              "regulatory",
              "domain",
              "soft-skill",
              "equipment",
              "vehicle",
              "trade",
              "other"
            ]
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "current": {
            "type": "boolean"
          },
          "visibility": {
            "$ref": "#/$defs/visibility"
          }
        },
        "additionalProperties": false
      }
    },
    "cautions": {
      "type": "array",
      "description": "Claims, framings, phrases, or assumptions the user does not want tools to make.",
      "items": {
        "type": "object",
        "required": [
          "claim"
        ],
        "properties": {
          "claim": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "addedDate": {
            "$ref": "#/$defs/partialDate"
          },
          "provenance": {
            "$ref": "#/$defs/provenance"
          },
          "visibility": {
            "$ref": "#/$defs/visibility"
          }
        },
        "additionalProperties": false
      }
    },
    "openQuestions": {
      "type": "array",
      "description": "Questions that should be asked later instead of inventing facts now.",
      "items": {
        "type": "object",
        "required": [
          "question"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "addedDate": {
            "$ref": "#/$defs/partialDate"
          },
          "provenance": {
            "$ref": "#/$defs/provenance"
          },
          "visibility": {
            "$ref": "#/$defs/visibility"
          }
        },
        "additionalProperties": false
      }
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    },
    "positioningVariants": {
      "type": "array",
      "description": "Target-aware positioning statements that span the career. In v0.3 this is constrained to headline variants; future versions may allow other positioning surfaces. These are not canonical facts by themselves; they are reusable presentation choices with provenance and review state.",
      "items": {
        "$ref": "#/$defs/positioningVariant"
      }
    },
    "talkingPoints": {
      "type": "array",
      "description": "Reusable cross-career patterns, interview themes, or positioning hypotheses that tools can cite when drafting resumes, cover letters, interviews, and coaching material. Talking points should be earned from evidence in the file, not manufactured as flattery.",
      "items": {
        "$ref": "#/$defs/talkingPoint"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "position": {
      "type": "object",
      "required": [
        "title",
        "dateRange"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "dateRange": {
          "$ref": "#/$defs/dateRange"
        },
        "summary": {
          "type": "string"
        },
        "achievements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/achievement"
          }
        },
        "techStack": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        }
      },
      "additionalProperties": false
    },
    "achievement": {
      "type": "object",
      "required": [
        "statement"
      ],
      "properties": {
        "statement": {
          "type": "string"
        },
        "longform": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "accomplishment",
            "responsibility",
            "project",
            "recognition",
            "other"
          ]
        },
        "attribution": {
          "type": "object",
          "description": "How directly the subject contributed to the outcome. Use this to keep verbs honest in downstream wording.",
          "properties": {
            "role": {
              "type": "string",
              "enum": [
                "owned",
                "led",
                "co-led",
                "drove",
                "contributed-to",
                "supported",
                "advised",
                "observed",
                "other"
              ]
            },
            "scope": {
              "type": "string"
            },
            "ownedBudget": {
              "type": "boolean"
            },
            "ownedHeadcount": {
              "type": "boolean"
            },
            "reportedUpward": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "narrativeVariants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "statement": {
                "type": "string"
              },
              "audiences": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "notes": {
                "type": "string"
              },
              "provenance": {
                "$ref": "#/$defs/provenance"
              }
            },
            "additionalProperties": false
          }
        },
        "supportingFacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "statement"
            ],
            "properties": {
              "statement": {
                "type": "string"
              },
              "visibility": {
                "$ref": "#/$defs/visibility"
              }
            },
            "additionalProperties": false
          }
        },
        "importance": {
          "type": "integer",
          "minimum": 1
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "from": {
          "type": "number"
        },
        "to": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "basis": {
          "type": "string",
          "enum": [
            "quota",
            "budget",
            "plan",
            "target",
            "forecast",
            "prior-year",
            "baseline",
            "other"
          ]
        },
        "basisLabel": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "value"
          ]
        },
        {
          "required": [
            "from",
            "to"
          ]
        }
      ],
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "description": "Open-shape provenance metadata. Prefer common keys such as source, tool, date, sourceArtifactId, confidence, operation, and note.",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "description": "Vendor or user-local extension metadata. Use domain-owned keys for vendors and top-level user.local for user-owned incubation.",
      "propertyNames": {
        "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$",
        "description": "A domain name owned by the vendor, or the interim user.local namespace for user-owned incubation. Must contain at least one dot; subdomains are allowed."
      },
      "additionalProperties": {
        "type": "object",
        "description": "Extension payload. OCF does not constrain its shape.",
        "additionalProperties": true
      }
    },
    "partialDate": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer"
        },
        "month": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31
        },
        "present": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "dateRange": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/$defs/partialDate"
        },
        "end": {
          "$ref": "#/$defs/partialDate"
        }
      },
      "additionalProperties": false
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "shared",
        "private"
      ]
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "unreviewed",
        "needs-review",
        "user-confirmed",
        "do-not-use",
        "superseded"
      ],
      "description": "Lightweight workflow state for durable user-facing or quoted content. unreviewed = captured but not checked by the user; needs-review = flagged for explicit review; user-confirmed = accepted by the user; do-not-use = retained only to prevent future reuse; superseded = replaced by newer wording or facts. This is not an institutional verification or proof tier."
    },
    "positioningVariant": {
      "type": "object",
      "required": [
        "kind",
        "headline"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable local ID for this positioning variant."
        },
        "kind": {
          "type": "string",
          "const": "headline",
          "description": "v0.3 only standardizes headline positioning variants."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label, e.g. Healthcare CISO headline, Federal cyber leadership headline."
        },
        "headline": {
          "type": "string",
          "description": "Target-aware headline text."
        },
        "audiences": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Audience tags this headline is useful for."
        },
        "targetRole": {
          "type": "string"
        },
        "targetCompany": {
          "type": "string"
        },
        "supportingItemIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Stable local IDs of OCF items that support this positioning."
        },
        "evidenceSummary": {
          "type": "string",
          "description": "Short explanation of why this positioning is earned."
        },
        "visibility": {
          "$ref": "#/$defs/visibilityShared"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "reviewStatus": {
          "$ref": "#/$defs/reviewStatus"
        },
        "reviewNote": {
          "type": "string",
          "description": "Short note explaining review status, correction, or remaining concern."
        },
        "reviewedBy": {
          "type": "string",
          "description": "Person or tool that last set or confirmed reviewStatus."
        },
        "reviewedDate": {
          "$ref": "#/$defs/partialDate"
        }
      },
      "additionalProperties": false
    },
    "talkingPoint": {
      "type": "object",
      "required": [
        "statement"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable local ID for this talking point."
        },
        "label": {
          "type": "string",
          "description": "Short label for tools and editors."
        },
        "statement": {
          "type": "string",
          "description": "The reusable through-line or talking point."
        },
        "uses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Where this can be useful, e.g. interview, cover-letter, resume-summary, linkedin, coaching."
        },
        "supportingItemIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Stable local IDs of OCF items that support this talking point."
        },
        "supportingEvidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "description": "Descriptive evidence kind, e.g. reflection, achievement, sourceArtifact."
              },
              "id": {
                "type": "string",
                "description": "Stable local ID of the evidence item when available."
              }
            },
            "additionalProperties": false
          },
          "description": "Fallback descriptive evidence pointers for supporting material that lacks an ID, or short human-readable evidence notes."
        },
        "evidenceSummary": {
          "type": "string",
          "description": "Short explanation of why this talking point is earned."
        },
        "visibility": {
          "$ref": "#/$defs/visibilityPrivate"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "reviewStatus": {
          "$ref": "#/$defs/reviewStatus"
        },
        "reviewNote": {
          "type": "string",
          "description": "Short note explaining review status, correction, or remaining concern."
        },
        "reviewedBy": {
          "type": "string",
          "description": "Person or tool that last set or confirmed reviewStatus."
        },
        "reviewedDate": {
          "$ref": "#/$defs/partialDate"
        }
      },
      "additionalProperties": false
    }
  }
}
